---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Editar serie">
  <a
    id="back-link"
    href="/"
    class="link link-hover text-base-content/50 text-sm flex items-center gap-1 mb-6"
    >← Volver al detalle</a
  >

  <h1 class="font-display text-4xl tracking-widest mb-1">Editar serie</h1>
  <p id="subtitle" class="text-base-content/50 text-sm mb-6 hidden">
    Modificando: <strong id="manga-title" class="text-base-content"></strong>
  </p>

  <div role="alert" class="alert alert-error mb-4 hidden" id="error-msg">
    <span id="error-text"></span>
  </div>

  <div id="loading" class="flex justify-center py-20">
    <span class="loading loading-spinner loading-lg text-primary"></span>
  </div>

  <div
    id="form-wrapper"
    class="card bg-base-200 border border-base-300 max-w-2xl hidden"
  >
    <div class="card-body">
      <form id="edit-form" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="form-control">
            <label class="label" for="title"
              ><span class="label-text">Título *</span></label
            >
            <input
              class="input input-bordered"
              type="text"
              id="title"
              name="title"
              required
            />
          </div>
          <div class="form-control">
            <label class="label" for="author"
              ><span class="label-text">Autor *</span></label
            >
            <input
              class="input input-bordered"
              type="text"
              id="author"
              name="author"
              required
            />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
          <div class="form-control">
            <label class="label" for="genre"
              ><span class="label-text">Género</span></label
            >
            <input
              class="input input-bordered"
              type="text"
              id="genre"
              name="genre"
            />
          </div>
          <div class="form-control">
            <label class="label" for="status"
              ><span class="label-text">Estado</span></label
            >
            <select class="select select-bordered" id="status" name="status">
              <option value="Ongoing">En emisión</option>
              <option value="Completed">Completado</option>
              <option value="Hiatus">En pausa</option>
            </select>
          </div>
        </div>

        <div class="form-control mt-4">
          <label class="label" for="chapters"
            ><span class="label-text">Número de capítulos</span></label
          >
          <input
            class="input input-bordered"
            type="number"
            id="chapters"
            name="chapters"
            min="1"
          />
        </div>

        <div class="form-control mt-4">
          <label class="label" for="synopsis"
            ><span class="label-text">Sinopsis</span></label
          >
          <textarea
            class="textarea textarea-bordered"
            id="synopsis"
            name="synopsis"></textarea>
        </div>

        <div class="form-control mt-4">
          <label class="label" for="imageUrl"
            ><span class="label-text">URL de imagen (portada)</span></label
          >
          <input
            class="input input-bordered"
            type="url"
            id="imageUrl"
            name="imageUrl"
          />
        </div>

        <div class="flex gap-3 mt-6">
          <button type="submit" class="btn btn-primary" id="submit-btn"
            >Guardar cambios</button
          >
          <a id="cancel-link" href="/" class="btn btn-ghost">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const mangaId = params.get("id");

  if (!mangaId) {
    window.location.href = "/";
  }

  // Set back/cancel links
  (document.getElementById("back-link") as HTMLAnchorElement).href =
    `/manga/detail?id=${mangaId}`;
  (document.getElementById("cancel-link") as HTMLAnchorElement).href =
    `/manga/detail?id=${mangaId}`;

  async function load() {
    const loading = document.getElementById("loading")!;
    const formWrapper = document.getElementById("form-wrapper")!;
    const subtitle = document.getElementById("subtitle")!;
    const errorMsg = document.getElementById("error-msg")!;
    const errorText = document.getElementById("error-text")!;

    try {
      const res = await fetch(`/api/manga/${mangaId}`);
      if (res.status === 404) {
        window.location.href = "/";
        return;
      }
      if (!res.ok) throw new Error();
      const manga = await res.json();

      document.title = `Editar — ${manga.title} | MangaTracker`;
      (document.getElementById("manga-title") as HTMLElement).textContent =
        manga.title;
      subtitle.classList.remove("hidden");

      (document.getElementById("title") as HTMLInputElement).value =
        manga.title;
      (document.getElementById("author") as HTMLInputElement).value =
        manga.author;
      (document.getElementById("genre") as HTMLInputElement).value =
        manga.genre ?? "";
      (document.getElementById("status") as HTMLSelectElement).value =
        manga.status;
      (document.getElementById("chapters") as HTMLInputElement).value =
        manga.chapters ?? "";
      (document.getElementById("synopsis") as HTMLTextAreaElement).value =
        manga.synopsis ?? "";
      (document.getElementById("imageUrl") as HTMLInputElement).value =
        manga.imageUrl ?? "";

      loading.classList.add("hidden");
      formWrapper.classList.remove("hidden");
    } catch {
      loading.classList.add("hidden");
      errorText.textContent = "No se pudo cargar la serie.";
      errorMsg.classList.remove("hidden");
    }
  }

  load();

  document
    .getElementById("edit-form")!
    .addEventListener("submit", async (e) => {
      e.preventDefault();
      const errorMsg = document.getElementById("error-msg")!;
      const errorText = document.getElementById("error-text")!;
      const submitBtn = document.getElementById(
        "submit-btn",
      ) as HTMLButtonElement;

      errorMsg.classList.add("hidden");
      submitBtn.disabled = true;
      submitBtn.textContent = "Guardando...";

      const data = {
        title: (
          document.getElementById("title") as HTMLInputElement
        ).value.trim(),
        author: (
          document.getElementById("author") as HTMLInputElement
        ).value.trim(),
        genre:
          (document.getElementById("genre") as HTMLInputElement).value.trim() ||
          null,
        status: (document.getElementById("status") as HTMLSelectElement).value,
        chapters: (document.getElementById("chapters") as HTMLInputElement)
          .value
          ? Number(
              (document.getElementById("chapters") as HTMLInputElement).value,
            )
          : null,
        synopsis:
          (
            document.getElementById("synopsis") as HTMLTextAreaElement
          ).value.trim() || null,
        imageUrl:
          (
            document.getElementById("imageUrl") as HTMLInputElement
          ).value.trim() || null,
      };

      if (!data.title || !data.author) {
        errorText.textContent = "El título y el autor son obligatorios.";
        errorMsg.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = "Guardar cambios";
        return;
      }

      try {
        const res = await fetch(`/api/manga/${mangaId}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          window.location.href = `/manga/detail?id=${mangaId}`;
        } else {
          errorText.textContent =
            "Error al guardar los cambios. Inténtalo de nuevo.";
          errorMsg.classList.remove("hidden");
          submitBtn.disabled = false;
          submitBtn.textContent = "Guardar cambios";
        }
      } catch {
        errorText.textContent =
          "Error de conexión. ¿Está el backend corriendo?";
        errorMsg.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = "Guardar cambios";
      }
    });
</script>
